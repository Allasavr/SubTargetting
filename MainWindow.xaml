<Window x:Class="SubTargetting.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SubTargetting"
        mc:Ignorable="d"
        Title="Трекер подписок" Height="337" Width="800" FontFamily="Times New Roman" FontSize="16" WindowStyle="None" WindowStartupLocation="CenterScreen" >
    <Window.Resources>
        <!-- Глобальный стиль для всех кнопок -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF95E0F9" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderThickness="1" BorderBrush="Black">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="0,3,0,0" RenderTransformOrigin="0.501,0.511">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FFB1CACF"/>
                <GradientStop Color="#FFD9EFF4" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Label Content="Подписка" HorizontalAlignment="Left" Margin="32,54,0,0" VerticalAlignment="Top" Width="80" Cursor="Arrow" HorizontalContentAlignment="Center" Background="#FFB8D0D5" BorderBrush="Black"/>
        <TextBox x:Name="SubTextBox"
                 HorizontalAlignment="Left" Margin="130,58,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Label Content="Дата" HorizontalAlignment="Left" Margin="290,54,0,0" VerticalAlignment="Top" Width="80" Cursor="Arrow" HorizontalContentAlignment="Center" Background="#FFB7CFD4" BorderBrush="Black"/>
        <TextBox x:Name="DataTextBox" 
                 GotFocus="MyTextBox_GotFocus" 
                 LostFocus="MyTextBox_LostFocus" 
                 Foreground="LightGray" 
                 Text="YYYY-MM-DD" 
            HorizontalAlignment="Left" Margin="375,58,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Label Content="Оплата" HorizontalAlignment="Left" Margin="529,54,0,0" VerticalAlignment="Top" Width="80" Cursor="Arrow" HorizontalContentAlignment="Center" Background="#FFB7CFD4" BorderBrush="Black"/>
        <TextBox x:Name="PaymentTextBox"
                 HorizontalAlignment="Left" Margin="616,58,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <GroupBox x:Name="CategoryGroupBox" HorizontalAlignment="Left" Margin="32,101,0,0" VerticalAlignment="Top" Width="218" BorderThickness="0,0,0,0">
            <StackPanel>
                <RadioButton Content="Медиа и развлечения" GroupName="Category" Name="MediaEntertainmentRadioButton"/>
                <RadioButton Content="Товары и услуги" GroupName="Category" Name="GoodServiceRadioButton"/>
                <RadioButton Content="Образование" GroupName="Category" Name="EducationRadioButton"/>
                <RadioButton Content="Фитнес и здоровье" GroupName="Category" Name="SportHealthRadioButton"/>
                <RadioButton Content="Игры" GroupName="Category" Name="GamesRadioButton"/>
                <RadioButton Content="Профессиональные услуги" GroupName="Category" Name="ProfServiceRadioButton"/>
                <RadioButton Content="Другое" GroupName="Category" Name="OtherRadioButton"/>
            </StackPanel>
        </GroupBox>
        <GroupBox x:Name="DurationGroupBox" HorizontalAlignment="Left" Margin="375,101,0,0" VerticalAlignment="Top" Width="120" BorderThickness="0,0,0,0">
            <StackPanel>
                <RadioButton Content="30 дней" GroupName="Duration" Name="ThirtyDaysRadioButton"/>
                <RadioButton Content="2 месяца" GroupName="Duration" Name="TwoMonthRadioButton" />
                <RadioButton Content="6 месяцев" GroupName="Duration" Name="SixMonthRadioButton"/>
                <RadioButton Content="1 год" GroupName="Duration" Name="YearRadioButton"/>
            </StackPanel>
        </GroupBox>
        <GroupBox x:Name="CurrencyGroupBox" HorizontalAlignment="Left" Margin="616,101,0,0" VerticalAlignment="Top" Width="120" BorderThickness="0,0,0,0">
            <StackPanel>
                <RadioButton Content="USD" GroupName="Currency" Name="USDRadioButton"/>
                <RadioButton Content="EUR" GroupName="Currency" Name="EURRadioButton"/>
                <RadioButton Content="RUB" GroupName="Currency" Name="RUBRadioButton"/>
                <RadioButton Content="CNY" GroupName="Currency" Name="CNYRadioButton"/>
            </StackPanel>
        </GroupBox>
        <Button x:Name="AddButton" Content="+Добавить подписку" HorizontalAlignment="Left" Margin="32,267,0,0" VerticalAlignment="Top" Width="166" Height="34" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave" Background="#FF95E0F9" Click="AddButton_Click" FontSize="14"/>
        <Label HorizontalAlignment="Center" VerticalAlignment="Top" Width="780" Background="#FFA4C0C6" Height="35" MouseDown="Label_MouseDown"/>
        <Label Content="Трекер подписок" HorizontalAlignment="Left" Margin="43,2,0,0" VerticalAlignment="Top" FontSize="16" Foreground="Black"/>
        <Image HorizontalAlignment="Left" Height="28" Margin="10,2,0,0" VerticalAlignment="Top" Width="35" Source="Source/9069020_view_list_icon.png" RenderTransformOrigin="0.479,0.61"/>
        <Polygon Fill="#FF384659" Opacity="0.5" Points="260,0,275,7,519,7,534,0"/>
        <Image Name="MinButton" HorizontalAlignment="Left" 
               Height="30" Margin="722,5,0,0" VerticalAlignment="Top" Width="28" MouseDown="MinButton_MouseDown" >
            <Image.Style>
                <Style TargetType="{x:Type Image}">
                    <Setter Property="Source" Value="Source\8685988_ic_fluent_line_horizontal_filled_icon.png"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName= MinButton}"
                                     Value="True">
                            <Setter Property="Source" Value="Source\icons8-горизонтальная-линия-50.png"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>
        <Image x:Name="ExitButton" HorizontalAlignment="Left" 
            Height="30" Margin="755,4,0,0" VerticalAlignment="Top" Width="30" MouseDown="ExitButton_MouseDown" >
            <Image.Style>
                <Style TargetType="{x:Type Image}">
                    <Setter Property="Source" Value="Source\icons8-крестик-78 (2).png"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=ExitButton}"
                            Value="True">
                            <Setter Property="Source" Value="Source/icons8-крестик-78 (3).png"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>
        <Button Name="PaymentHistory" Content="Показать историю платежей" HorizontalAlignment="Left" Margin="569,267,0,0" VerticalAlignment="Top" Height="34" Width="201" Click="PaymentHistory_Click" FontSize="14" MouseLeave="PaymentHistory_MouseLeave_1" MouseEnter="PaymentHistory_MouseEnter_1" Background="#FF95E0F9"/>
    </Grid>
</Window>
