<Window x:Class="SubTargetting.EnteranceWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SubTargetting"
                mc:Ignorable="d"
        Title="Трекер подписок" Height="337" Width="800" FontFamily="Times New Roman" FontSize="16" WindowStyle="None" WindowStartupLocation="CenterScreen" >
    <Window.Resources>
        <!-- Глобальный стиль для всех кнопок -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="9" Background="{TemplateBinding Background}" BorderThickness="1" BorderBrush="Black">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="0,3,0,0" RenderTransformOrigin="0.501,0.511">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FFB1CACF"/>
                <GradientStop Color="#FFD9EFF4" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Label HorizontalAlignment="Center" VerticalAlignment="Top" Width="780" Background="#FFA4C0C6" Height="35" MouseDown="Label_MouseDown"/>
        <Image HorizontalAlignment="Left" Height="39" Margin="218,43,0,0" VerticalAlignment="Top" Width="43" Source="Source/9069020_view_list_icon.png" RenderTransformOrigin="0.479,0.61"/>
        <Polygon Fill="#FF384659" Opacity="0.5" Points="260,0,275,7,519,7,534,0"/>
        <Image Name="MinButton1" HorizontalAlignment="Left" 
               Height="30" Margin="722,5,0,0" VerticalAlignment="Top" Width="28" MouseDown="MinButton1_MouseDown" >
            <Image.Style>
                <Style TargetType="{x:Type Image}">
                    <Setter Property="Source" Value="Source\8685988_ic_fluent_line_horizontal_filled_icon.png"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName= MinButton1}"
                                     Value="True">
                            <Setter Property="Source" Value="Source\icons8-горизонтальная-линия-50.png"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>
        <Image x:Name="ExitButton1" HorizontalAlignment="Left" 
            Height="30" Margin="755,4,0,0" VerticalAlignment="Top" Width="30" MouseDown="ExitButton1_MouseDown" >
            <Image.Style>
                <Style TargetType="{x:Type Image}">
                    <Setter Property="Source" Value="Source\icons8-крестик-78 (2).png"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=ExitButton1}"
                            Value="True">
                            <Setter Property="Source" Value="Source/icons8-крестик-78 (3).png"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>
        <Label Content="Трекер подписок" HorizontalAlignment="Center" Margin="0,19,0,0" VerticalAlignment="Top" FontSize="36" Foreground="Black" Height="87" Width="312" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        <GroupBox x:Name="CurrencyStartGroupBox" HorizontalAlignment="Center" Margin="0,167,0,0" VerticalAlignment="Top" Width="220" BorderThickness="0,0,0,0">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
                <RadioButton Content="USD" GroupName="Currency" x:Name="USDRadioButton"/>
                <RadioButton Content="EUR" GroupName="Currency" x:Name="EURRadioButton"/>
                <RadioButton Content="CNY" GroupName="Currency" x:Name="CNYRadioButton"/>
                <RadioButton Content="RUB" GroupName="Currency" x:Name="RUBRadioButton"/>
            </StackPanel>
        </GroupBox>
        <Label Content="Настройка валюты" Margin="322,106,322,0" VerticalAlignment="Top" FontSize="18" Height="32"/>
        <Button Name="StartButton"  Content="Начать" HorizontalAlignment="Center" Margin="0,224,0,0" VerticalAlignment="Top" Height="38" Width="164" Background="#FF95E0F9" MouseLeave="Button_MouseLeave" MouseEnter="Button_MouseEnter" Click="StartButton_Click" BorderBrush="#FF076CC6"/>
    </Grid>
</Window>
